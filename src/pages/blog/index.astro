---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get URL parameters
const { page = 1, category } = Astro.url.searchParams;
const currentPage = parseInt(page.toString());
const postsPerPage = 9;

// Fetch posts
let posts = await getCollection('posts');

// Filter by category if specified
if (category) {
  posts = posts.filter(post => post.data.categories.includes(category));
}

// Sort by date
posts = posts.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());

// Calculate pagination
const totalPosts = posts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const paginatedPosts = posts.slice(startIndex, endIndex);

// Get unique categories
const categories = [...new Set(posts.flatMap(post => post.data.categories))];
---

<BaseLayout title="Blog" description="Latest articles and insights from Paintaire">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-4xl font-bold text-primary mb-8">Blog</h1>
    
    <!-- Category Filter -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2">
        <a 
          href="/blog" 
          class={`px-4 py-2 rounded-full text-sm ${!category ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}
        >
          All
        </a>
        {categories.map(cat => (
          <a 
            href={`/blog?category=${cat}`}
            class={`px-4 py-2 rounded-full text-sm ${category === cat ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}
          >
            {cat.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
          </a>
        ))}
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      {paginatedPosts.map(post => (
        <article class="bg-white rounded-lg shadow-md overflow-hidden">
          {post.data.image && (
            <img 
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-48 object-cover"
            />
          )}
          <div class="p-6">
            <h2 class="text-xl font-semibold mb-2">
              <a href={`/blog/${post.slug}`} class="text-primary hover:text-secondary">
                {post.data.title}
              </a>
            </h2>
            <p class="text-gray-600 mb-4">{post.data.excerpt}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500">
                {new Date(post.data.publishedDate).toLocaleDateString()}
              </span>
              {post.data.categories && post.data.categories.length > 0 && (
                <span class="text-sm text-accent">
                  {post.data.categories[0].split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
                </span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex justify-center gap-2 mb-8">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(pageNum => (
          <a
            href={`/blog?page=${pageNum}${category ? `&category=${category}` : ''}`}
            class={`px-4 py-2 rounded ${pageNum === currentPage ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}
          >
            {pageNum}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>