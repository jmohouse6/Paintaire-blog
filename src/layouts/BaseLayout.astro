---
import { SEO } from 'astro-seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  author?: string;
  keywords?: string[];
}

const { 
  title, 
  description, 
  image,
  type = 'website',
  publishedDate,
  modifiedDate,
  author,
  keywords = []
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultDescription = "Paintaire's official blog for painting tips, industry news, and expert insights";
const defaultImage = '/images/default-og.jpg';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={`${title} | Paintaire Blog`}
      description={description || defaultDescription}
      canonical={canonicalURL.toString()}
      openGraph={{
        basic: {
          title: title,
          type: type,
          image: image || defaultImage,
          url: canonicalURL.toString(),
        },
        optional: {
          description: description || defaultDescription,
          locale: 'en_US',
          siteName: 'Paintaire Blog',
        },
        article: type === 'article' ? {
          publishedTime: publishedDate?.toISOString(),
          modifiedTime: modifiedDate?.toISOString(),
          authors: [author || 'Paintaire'],
          tags: keywords,
        } : undefined,
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@paintaire',
        creator: '@paintaire',
        title: title,
        description: description || defaultDescription,
        image: image || defaultImage,
      }}
      extend={{
        meta: [
          { name: 'keywords', content: keywords.join(', ') },
          { name: 'author', content: author || 'Paintaire' },
          ...publishedDate ? [{ name: 'article:published_time', content: publishedDate.toISOString() }] : [],
          ...modifiedDate ? [{ name: 'article:modified_time', content: modifiedDate.toISOString() }] : [],
        ],
        link: [
          { rel: 'alternate', type: 'application/rss+xml', href: '/rss.xml', title: 'RSS Feed' },
        ],
      }}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <script is:inline>
      // Dark mode script...
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-900 dark:text-gray-100 transition-colors">
    <Header />
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>