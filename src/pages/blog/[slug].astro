---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Get author data
const authors = await getCollection('authors');
const author = authors.find(a => a.slug === post.data.author);

// Determine theme for comments
const theme = Astro.cookies.get('theme')?.value === 'dark' ? 'dark' : 'light';

// Extract keywords from categories and title
const keywords = [
  ...post.data.categories,
  ...post.data.title.toLowerCase().split(' '),
  'painting',
  'paint tips',
  'professional painting',
  author?.data.name.toLowerCase() || ''
].filter(Boolean);
---

<BaseLayout 
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.image}
  type="article"
  publishedDate={post.data.publishedDate}
  author={author?.data.name}
  keywords={keywords}
>
  <article class="max-w-4xl mx-auto" itemscope itemtype="http://schema.org/BlogPosting">
    <meta itemprop="datePublished" content={post.data.publishedDate.toISOString()} />
    {author && <meta itemprop="author" content={author.data.name} />}
    
    <!-- Header -->
    <header class="mb-8">
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full h-[400px] object-cover rounded-lg mb-6"
          itemprop="image"
        />
      )}
      <h1 class="text-4xl font-bold text-primary dark:text-white mb-4" itemprop="headline">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-6 text-gray-600 dark:text-gray-300 mb-4">
        <div class="flex items-center gap-2" itemprop="author" itemscope itemtype="http://schema.org/Person">
          {author?.data.avatar && (
            <img
              src={author.data.avatar}
              alt={author.data.name}
              class="w-8 h-8 rounded-full"
            />
          )}
          <span itemprop="name">{author?.data.name}</span>
        </div>
        <time datetime={post.data.publishedDate.toISOString()} itemprop="datePublished">
          {new Date(post.data.publishedDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>
      <div class="flex gap-2">
        {post.data.categories.map(category => (
          <a
            href={`/blog?category=${category}`}
            class="px-3 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full text-sm hover:bg-gray-200 dark:hover:bg-gray-600"
          >
            {category.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
          </a>
        ))}
      </div>
    </header>

    <!-- Content -->
    <div class="prose dark:prose-invert prose-lg max-w-none" itemprop="articleBody">
      <Content />
    </div>

    <!-- Rest of the component... -->
  </article>
</BaseLayout>